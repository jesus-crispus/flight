[sub_resource type="Shader" id="Shader_2oeqo"]
code = "shader_type canvas_item;

uniform vec2 size = vec2(16.0, 14.0);
// If you intend to read from mipmaps with `textureLod()` LOD values greater than `0.0`,
// use `filter_nearest_mipmap` instead. This shader doesn't require it.
uniform sampler2D screen_texture : hint_screen_texture, repeat_disable, filter_nearest;
uniform float range_start = 0.5;
uniform float range_end = 1.1;





uint hash( uint x ) {
    x += ( x << 10u );
    x ^= ( x >>  6u );
    x += ( x <<  3u );
    x ^= ( x >> 11u );
    x += ( x << 15u );
    return x;
}

uint hash2( uvec3 v ) { return hash( v.x ^ hash(v.y) ^ hash(v.z)             ); }

float floatConstruct( uint m ) {
    const uint ieeeMantissa = 0x007FFFFFu; // binary32 mantissa bitmask
    const uint ieeeOne      = 0x3F800000u; // 1.0 in IEEE binary32

    m &= ieeeMantissa;                     // Keep only mantissa bits (fractional part)
    m |= ieeeOne;                          // Add fractional part to 1.0

    float  f = uintBitsToFloat( m );       // Range [1:2]
    return f - 1.0;                        // Range [0:1]
}


float random( vec3  v ) { return floatConstruct(hash2(floatBitsToUint(v))); }




void fragment() {
	vec3  inputs = vec3( SCREEN_UV.xy, TIME );

	float random_number = random(inputs) * (range_end - range_start) + range_start ;

	vec4 color = textureLod(screen_texture, SCREEN_UV ,1.0) * vec4(1,1,1,1);

	COLOR = (vec4(color.rgb * random_number, color.w));


}"

