[sub_resource type="GDScript" id="GDScript_iyf2y"]
script/source = "extends MeshInstance3D

@export var RAY_LENGTH: float
@onready var racast_mesh_instance = $bob
@onready var racast_prediction_mesh_instance = %prediction

var cone_angle = deg_to_rad(10*2)



var position_saved: Vector3
var rotation_saved: Vector3

func _physics_process(delta: float) -> void:
	if position_saved != self.position or rotation_saved != self.rotation:
		raycast()
		position_saved = position
		rotation_saved = rotation

func raycast():
	
	var space_state = get_world_3d().direct_space_state
	
	var direction = self.basis.y
	
	
	var origin = self.global_position
	var end = self.global_position + (self.basis.y * RAY_LENGTH )
	var query = PhysicsRayQueryParameters3D.create(origin, end)
	query.collide_with_areas = true
	query.collide_with_bodies = true
	
	
	
	var result = space_state.intersect_ray(query)
	
	
	var raycast_mesh = ImmediateMesh.new()
	if result:
		
		
		calculate_distance(result)
		
		
		
		var distance_traveled = origin.distance_to(result.position)
		
		
		#print(distance_traveled)
		
		raycast_mesh.surface_begin(Mesh.PRIMITIVE_LINES)
		raycast_mesh.surface_add_vertex(origin)
		raycast_mesh.surface_add_vertex(result.position)
		
		
		raycast_mesh.surface_add_vertex(result.position)
		raycast_mesh.surface_add_vertex(result.position + -result.normal)
		
		var query2 = PhysicsRayQueryParameters3D.create(result.position, end)
		query2.collide_with_areas = true
		var result2 = space_state.intersect_ray(query2)
		
		if result2:
			
			
			
			
			var radius1 = Vector2(result.position.x, result.position.z).length()
			var radius2 = Vector2(result.position.x, result.position.z).length()
			
			var  diamiter = radius1*2
			
			
			result.position 
			
			
			
			raycast_mesh.surface_add_vertex(result.position)
			raycast_mesh.surface_add_vertex(result2.position)
			
			raycast_mesh.surface_add_vertex(result2.position)
			raycast_mesh.surface_add_vertex(result2.position + (result2.normal * -Vector3(1,1,1)))
			
			var distance_to_cone_origin = result.position.distance_to(Vector3(0,0,0))
			
			
			
			var cone_angle_vector = (result.position.normalized()) * Vector3(-1,1,-1)
			
