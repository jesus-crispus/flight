func calculate_distance(result) -> float:
	
	
	
	var cone_angle =  deg_to_rad(10.0 * 2.0);
	var cone_start_psition = Vector3(0,500,0)
	var modelview_matrix = %CollisionShape3D.global_transform
	var fragment_global_position = result.position
	var fragment_local_position = ( fragment_global_position * modelview_matrix) + Vector3(0,500,0)
	
	var direction_from_camera = self.basis.y
	var local_direction_from_camera = direction_from_camera * modelview_matrix.basis
	var local_normals = result.normal
	var distance_to_cone_origin = fragment_local_position.length()
	var cone_angle_vector = (fragment_local_position.normalized()) * Vector3(-1,1,-1)
	var radius = Vector2(fragment_local_position.x, fragment_local_position.z).length()
	
	
	#var angle =  (1 - local_direction_from_camera.angle_to(cone_angle_vector * Vector3(1,-1,1)))
	var angle = atan2( local_direction_from_camera.cross(cone_angle_vector * Vector3(1,-1,1)).length(), local_direction_from_camera.dot(cone_angle_vector * Vector3(1,-1,1)))
	
	var end_angle = (PI - cone_angle - angle )
	
	
	
	
	var distance = sin(cone_angle) * (distance_to_cone_origin/ sin(end_angle))
	
	var forward_direction = abs(Vector2(local_direction_from_camera.x,local_direction_from_camera.z).normalized())
	var direction_to_middle = abs(Vector2(fragment_local_position.x,fragment_local_position.z).normalized())
	var scalar =  abs(forward_direction.dot(direction_to_middle))
	
	print(scalar)
	
	distance = distance * scalar
	
	
	var position_prediction = fragment_local_position + local_direction_from_camera * distance
	
	var racast_prediction_mesh = ImmediateMesh.new()
	racast_prediction_mesh.surface_begin(Mesh.PRIMITIVE_LINES)
	racast_prediction_mesh.surface_add_vertex(fragment_local_position)
	racast_prediction_mesh.surface_add_vertex(fragment_local_position + local_direction_from_camera * distance)
	
	racast_prediction_mesh.surface_add_vertex(Vector3(0,0,0))
	racast_prediction_mesh.surface_add_vertex(((cone_angle_vector * Vector3(1,-1,1))) * 100)
	
	racast_prediction_mesh.surface_add_vertex(Vector3(0,0,0))
	racast_prediction_mesh.surface_add_vertex(position_prediction)
	
	racast_prediction_mesh.surface_end()
	racast_prediction_mesh_instance.mesh = racast_prediction_mesh
	
	print(\"prediction2  : \",distance,\"  \", local_direction_from_camera,\"  \",direction_from_camera,\"  \", fragment_local_position)
	print(cone_angle,\"  \",angle,\"  \",end_angle,\"  \",cone_angle + angle + end_angle)
	
	
	return distance
"

