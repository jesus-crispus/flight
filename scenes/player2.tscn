	start_hight = self.position.z
	self.position.z = start_hight + zoom_start
	enviorment = player.enviorment_var 
	exposure = enviorment.environment.tonemap_exposure
	enviorment.environment.tonemap_exposure = 0
	
	
	objective = player.objective
	
# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	

	var distance = (self.global_position * Vector3(1,1,0)).distance_to(objective.position)
	
	if distance <= 30  and game_over == false:
		game_over = true
		set_as_top_level(true)
		lerp_start.x = position.x
		lerp_start.y = position.y
	
	#if distance <= 30 and softlock_active_prevention == false:
		#softlock_active_prevention = true
		##%SoftlockPreventionTimer.start()
	
	if game_over == true:
		lerp_time = clampf(lerp_time +(delta * 0.1),0,1)
		var lerp_vector = lerp(lerp_start,Vector2(0,0),lerp_time)

		
		self.position.x = lerp_vector.x
		self.position.y = lerp_vector.y

	var clamped_var = clampf(distance/ending_start_distance ,0,max_curve_output)
	
	if clamped_var <= 0.01:
		pass
		max_curve_output = clamped_var
	
	
	var curve_sample = ending_curve.sample(clamped_var)

	
	self.position.z  = start_hight + curve_sample
	
	if  clamped_var *10 <= triger_distance_x10 :
		#print(\"clamped_var : \",clamped_var)
		game_over = true
		
		player.win()
	
	else:
		
		if start_animation:
			time += delta * speed
			
			var multiplier = curve.sample(time)
			
			self.position.z = start_hight + (zoom_start * multiplier)
			
			enviorment.environment.tonemap_exposure = exposure * (1 - multiplier)
			#print(\"exposure : \",enviorment.environment.tonemap_exposure)
			#%MeshInstance3D.position.x = x_curve.sample(time)
		if time >= 1:
			start_animation = false
			
		
		
	if game_over == false:
		look_at(player.position)
"

