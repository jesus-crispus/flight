//render_mode world_vertex_coords;

void vertex() {
	// Called for every vertex the material is visible on.
	vec3 direction_to_world_origin = (normalize(vec4(-VERTEX,0) * MODEL_MATRIX) * inverse(MODEL_MATRIX)).xyz;
	
	//float multiplier = ;
	
	VERTEX  += clamp(dot(NORMAL,direction_to_world_origin),0,1) * direction_to_world_origin;
	
	
	
}

