	ALPHA = (distance_traveld_through_volume/1000.0) * inversesqrt(distance_to_cone_origin) * light_energy;

	//ALBEDO.x = (distance_traveld_through_volume/1000.0) * 0.5;
	//ALBEDO.y = (distance_traveld_through_volume/1000.0) * 0.5;
	//ALBEDO.z = (distance_traveld_through_volume/1000.0) * 0.5;

	// Called for every pixel the material is visible on.
}








