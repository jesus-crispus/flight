code = "shader_type spatial;
render_mode shadows_disabled, unshaded;
//, cull_disabled

uniform sampler2D image : source_color;

uint hash( uint x ) {
    x += ( x << 10u );
    x ^= ( x >>  6u );
    x += ( x <<  3u );
    x ^= ( x >> 11u );
    x += ( x << 15u );
    return x;
}

uint hash2( uvec3 v ) { return hash( v.x ^ hash(v.y) ^ hash(v.z)             ); }

float floatConstruct( uint m ) {
    const uint ieeeMantissa = 0x007FFFFFu; // binary32 mantissa bitmask
    const uint ieeeOne      = 0x3F800000u; // 1.0 in IEEE binary32

    m &= ieeeMantissa;                     // Keep only mantissa bits (fractional part)
    m |= ieeeOne;                          // Add fractional part to 1.0

    float  f = uintBitsToFloat( m );       // Range [1:2]
    return f - 1.0;                        // Range [0:1]
}


float random( vec3  v ) { return floatConstruct(hash2(floatBitsToUint(v))); }




const float light_energy = 10.0;
const float cone_angle =  radians(10.0 *2.0);
const vec3 cone_origin = vec3(0,500,0);
const float cone_hieght_offset = float(-500);



varying mat4 modelview_matrix;
varying vec3 camera_position;
varying vec3 local_normals;
varying vec3 position;
varying float distance_to_cone_origin;


//const float attenuation = 2.0;

void vertex() {

	position = vec3(VERTEX.x, VERTEX.y, VERTEX.z) + cone_origin;

	local_normals = NORMAL;

	distance_to_cone_origin = distance(VERTEX, cone_origin);

	modelview_matrix = MODELVIEW_MATRIX ;

	//camera_position = CAMERA_POSITION_WORLD * ;

