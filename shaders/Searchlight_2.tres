void fragment() {


	float random_number = random(vec3( FRAGCOORD.xy, TIME ));


	//vec3 bob =  abs(NORMAL - vec3(0,0,1));//COLOR.rgb;
	//float bob2 = bob.x + bob.y + bob.z;
	float depth_x = abs(NORMAL.x);
	float depth_y = (abs(NORMAL.y));
	float depth_z = ((NORMAL.z - 0.5));


	vec4 local_view =  (vec4(VIEW,1) * modelview_matrix);


	vec4 bob = modelview_matrix * vec4(VIEW,1);

	vec3 cone_angle_vector = (normalize(position)) * vec3(-1,1,-1);


	float angle = 1.0 - dot(VIEW,(cone_angle_vector * vec3(1,-1,1)));


	float unknown_angle = PI - cone_angle - cone_angle;



	float distance_traveld_through_volume = sin(cone_angle) * (distance_to_cone_origin/ sin(unknown_angle));

	vec2 direction_to_middle = normalize(vec2(position.x, position.z));

	vec3 forward_direction = normalize(abs(vec3(local_view.x,local_view.y,local_view.z)));

	float scalar = dot(forward_direction, abs(vec3(direction_to_middle.x,0,direction_to_middle.y)));

	//distance_traveld_through_volume = distance_traveld_through_volume * scalar;


	//vec4 test =
